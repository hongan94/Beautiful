<%= form_with(model: [:admin, user_group], local: true, class: "space-y-8") do |form| %>
  <% if user_group.errors.any? %>
    <div class="bg-danger/10 text-danger p-4 rounded-lg mb-6">
      <h2 class="font-semibold mb-2"><%= pluralize(user_group.errors.count, "error") %> prohibited this group from being saved:</h2>
      <ul class="list-disc list-inside text-sm">
        <% user_group.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
      <%= form.text_field :name, class: "input w-full px-4 py-2 border rounded-lg focus:ring-primary focus:border-primary dark:bg-coal-600 dark:border-gray-600 dark:text-gray-200", placeholder: "e.g. Content Creators" %>
    </div>
    
    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
      <%= form.text_field :description, class: "input w-full px-4 py-2 border rounded-lg focus:ring-primary focus:border-primary dark:bg-coal-600 dark:border-gray-600 dark:text-gray-200", placeholder: "Brief description of the role..." %>
    </div>
  </div>

  <div class="border-t border-gray-200 dark:border-gray-700 pt-6 mt-8">
    <div class="flex flex-col md:flex-row items-center justify-between mb-6 gap-4">
      <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 m-0">Permissions Allocation</h3>
      <div class="flex items-center gap-3 w-full md:w-auto">
        <div class="relative w-full md:w-64">
          <i class="ki-filled ki-magnifier absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
          <input type="text" id="permission-search" class="input w-full pl-10 py-2 border rounded-lg text-sm focus:ring-primary focus:border-primary dark:bg-coal-600 dark:border-gray-600 dark:text-gray-200" placeholder="Search modules...">
        </div>
        <button type="button" id="btn-select-all" class="btn btn-light btn-sm py-2 px-3 rounded-lg border border-gray-200 dark:border-gray-600 text-sm font-medium hover:bg-gray-100 dark:hover:bg-coal-400 transition-colors whitespace-nowrap">Select All</button>
        <button type="button" id="btn-deselect-all" class="btn btn-light btn-sm py-2 px-3 rounded-lg border border-gray-200 dark:border-gray-600 text-sm font-medium hover:bg-gray-100 dark:hover:bg-coal-400 transition-colors whitespace-nowrap">Clear All</button>
      </div>
    </div>
    
    <% if permissions.present? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="permissions-container">
        <% permissions.each do |subject_class, perms| %>
          <div class="permission-card border border-gray-100 dark:border-coal-400 rounded-xl p-5 bg-gray-50/50 dark:bg-coal-600/30 transition-all duration-200 hover:shadow-sm">
            <div class="flex items-center justify-between mb-4 pb-2 border-b border-gray-200 dark:border-coal-400">
              <div class="flex items-center">
                <i class="ki-filled ki-setting-2 text-primary me-2 text-lg"></i>
                <h4 class="permission-title font-bold text-gray-900 dark:text-gray-200 uppercase tracking-wide text-xs"><%= subject_class %></h4>
              </div>
              <label class="flex items-center cursor-pointer">
                <input type="checkbox" class="select-all-module checkbox size-4 rounded border-gray-300 text-primary focus:ring-primary dark:border-gray-600 dark:bg-coal-500" title="Select all in <%= subject_class %>">
                <span class="ms-2 text-xs font-medium text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">All</span>
              </label>
            </div>
            
            <div class="space-y-3">
              <% perms.each do |permission| %>
                <label class="flex items-center cursor-pointer group">
                  <%= check_box_tag "user_group[permission_ids][]", permission.id, user_group.permission_ids.include?(permission.id), class: "permission-checkbox checkbox size-4 rounded border-gray-300 text-primary focus:ring-primary dark:border-gray-600 dark:bg-coal-500" %>
                  <span class="ms-3 text-sm font-medium text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors">
                    <%= permission.action.titleize %>
                  </span>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8 text-gray-400 dark:text-gray-500">
        <i class="ki-filled ki-information text-3xl mb-3 block"></i>
        <p>No permissions found in the database. Please run seed data to generate permissions.</p>
      </div>
    <% end %>
  </div>

  <div class="flex justify-end gap-3 pt-6 border-t border-gray-200 dark:border-gray-700 mt-8">
    <a href="<%= admin_user_groups_path %>" class="btn btn-light dark:bg-coal-400 dark:text-gray-300 dark:hover:bg-coal-300 py-2 px-6 rounded-lg font-medium transition-colors">Cancel</a>
    <%= form.submit "Save Group", class: "btn btn-primary dark:bg-primary text-white py-2 px-6 rounded-lg shadow-sm font-medium hover:bg-primary-active transition-colors cursor-pointer" %>
  </div>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Global Select/Deselect All
    const btnSelectAll = document.getElementById('btn-select-all');
    const btnDeselectAll = document.getElementById('btn-deselect-all');
    const allCheckboxes = document.querySelectorAll('.permission-checkbox');
    const moduleSelectAllCheckboxes = document.querySelectorAll('.select-all-module');

    if (btnSelectAll) {
      btnSelectAll.addEventListener('click', () => {
        allCheckboxes.forEach(cb => cb.checked = true);
        moduleSelectAllCheckboxes.forEach(cb => cb.checked = true);
      });
    }

    if (btnDeselectAll) {
      btnDeselectAll.addEventListener('click', () => {
        allCheckboxes.forEach(cb => cb.checked = false);
        moduleSelectAllCheckboxes.forEach(cb => cb.checked = false);
      });
    }

    // Module specific select all
    const permissionCards = document.querySelectorAll('.permission-card');
    permissionCards.forEach(card => {
      const selectAllCb = card.querySelector('.select-all-module');
      const itemCbs = card.querySelectorAll('.permission-checkbox');
      
      const updateSelectAllState = () => {
        const allChecked = Array.from(itemCbs).every(cb => cb.checked);
        const someChecked = Array.from(itemCbs).some(cb => cb.checked);
        selectAllCb.checked = allChecked;
        selectAllCb.indeterminate = !allChecked && someChecked;
      };

      updateSelectAllState(); // Initial check

      itemCbs.forEach(cb => {
        cb.addEventListener('change', updateSelectAllState);
      });

      selectAllCb.addEventListener('change', (e) => {
        itemCbs.forEach(cb => {
          cb.checked = e.target.checked;
        });
      });
    });

    // Real-time Search Filter
    const searchInput = document.getElementById('permission-search');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase().trim();
        let visibleCount = 0;
        
        permissionCards.forEach(card => {
          const title = card.querySelector('.permission-title').textContent.toLowerCase();
          const items = Array.from(card.querySelectorAll('.permission-checkbox')).map(cb => cb.nextElementSibling.textContent.toLowerCase().trim());
          
          if (title.includes(term) || items.some(text => text.includes(term))) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        // Handle empty state gracefully
        const container = document.getElementById('permissions-container');
        let emptyState = document.getElementById('permissions-empty-state');
        
        if (visibleCount === 0 && term !== '') {
          if (!emptyState) {
            emptyState = document.createElement('div');
            emptyState.id = 'permissions-empty-state';
            emptyState.className = 'col-span-full text-center py-8 text-gray-500';
            emptyState.innerHTML = '<i class="ki-filled ki-search-list text-3xl mb-3 block text-gray-400"></i><p>No modules match your search.</p>';
            container.appendChild(emptyState);
          }
          emptyState.style.display = 'block';
        } else if (emptyState) {
          emptyState.style.display = 'none';
        }
      });
    }
  });
</script>
