    <%= form_with(model: @manager, url: @manager.persisted? ? admin_manager_path(@manager) : admin_managers_path, local: true, html: {multipart: true, id: "manager-form"}, method: @manager.persisted? ? :patch : :post) do |f| %>
      <% if @manager.errors.any? %>
        <div class="bg-danger/10 text-danger p-5 rounded-2xl mb-8 border border-danger/20 shadow-sm mx-8 mt-8">
          <h2 class="font-bold flex items-center mb-2 uppercase tracking-tight text-sm"><i class="ki-filled ki-warning-2 text-xl me-2"></i> Fix validation errors:</h2>
          <ul class="list-disc list-inside text-sm ms-2 font-medium opacity-90">
            <% @manager.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <div class="card bg-white dark:bg-coal-600 shadow-sm rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="p-8 lg:p-10 space-y-12">
          
          <!-- General Identification -->
          <div class="space-y-10">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-100 dark:border-gray-700">
              <i class="ki-filled ki-profile-circle text-primary text-2xl"></i>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white">Admin Identity</h3>
            </div>

            <div class="flex items-center gap-8 px-2">
              <div class="relative group size-24 rounded-full border-2 border-gray-200 dark:border-gray-700 overflow-hidden cursor-pointer shadow-sm">
                <div id="manager_avatar_preview_container" class="size-full">
                  <% if @manager.avatar_url.attached? %>
                    <%= image_tag @manager.avatar_url, id: "manager_avatar_preview", class: "size-full object-cover" %>
                  <% else %>
                    <div class="size-full bg-gray-100 dark:bg-coal-700 flex items-center justify-center">
                      <i id="manager_avatar_placeholder_icon" class="ki-filled ki-user text-4xl text-gray-400"></i>
                    </div>
                  <% end %>
                </div>
                <%= f.file_field :avatar_url, id: "manager_avatar_input", accept: "image/*", class: "absolute inset-0 opacity-0 cursor-pointer z-10" %>
                <div class="absolute inset-0 bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center pointer-events-none">
                  <i class="ki-filled ki-camera text-white text-2xl"></i>
                </div>
              </div>
              <div>
                <h4 class="text-base font-semibold text-gray-800 dark:text-gray-100">Manager Photo</h4>
                <p class="text-sm text-gray-500 mt-0.5">Square ratio image recommended</p>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
              <div class="space-y-2">
                <%= f.label :first_name, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.text_field :first_name, class: "input w-full h-12 px-4 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary focus:border-primary transition-all font-medium", placeholder: "First Name", required: true %>
              </div>
              <div class="space-y-2">
                <%= f.label :last_name, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.text_field :last_name, class: "input w-full h-12 px-4 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary focus:border-primary transition-all font-medium", placeholder: "Last Name", required: true %>
              </div>
              <div class="space-y-2">
                <%= f.label :email_address, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.email_field :email_address, class: "input w-full h-12 px-4 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary focus:border-primary transition-all font-medium", placeholder: "Email address", required: true %>
              </div>
              <div class="space-y-2">
                <%= f.label :phone_number, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.telephone_field :phone_number, class: "input w-full h-12 px-4 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary focus:border-primary transition-all font-medium", placeholder: "Phone number", required: true %>
              </div>
              <div class="space-y-2">
                <%= f.label :gender, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.select :gender, [['Male', 'male'], ['Female', 'female'], ['Other', 'other']], { include_blank: 'Select gender' }, class: "select w-full h-12 rounded-xl" %>
              </div>
              <div class="space-y-2">
                <%= f.label :status, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.select :status, [['Active', 'active'], ['Inactive', 'inactive']], {}, class: "select w-full h-12 rounded-xl" %>
              </div>
              <div class="md:col-span-2 space-y-2">
                <%= f.label :address, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.text_field :address, class: "input w-full h-12 px-4 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary focus:border-primary transition-all font-medium", placeholder: "Home or Office Address" %>
              </div>
            </div>
          </div>

          <!-- Security Credentials -->
          <div class="space-y-10 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-100 dark:border-gray-700">
              <i class="ki-filled ki-shield-tick text-primary text-2xl"></i>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white">Account Security</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
              <div class="space-y-2">
                <%= f.label :password, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.password_field :password, class: "input w-full h-12 px-4 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary focus:border-primary transition-all", placeholder: "Enter new password" %>
              </div>
              <div class="space-y-2">
                <%= f.label :password_confirmation, class: "text-sm font-semibold text-gray-700 dark:text-gray-300" %>
                <%= f.password_field :password_confirmation, class: "input w-full h-12 px-4 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary focus:border-primary transition-all", placeholder: "Confirm new password" %>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer Actions -->
        <div class="px-8 py-6 flex items-center justify-end gap-3 border-t border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-coal-700/30 rounded-b-2xl">
          <a href="<%= admin_managers_path %>" class="btn btn-sm btn-light dark:btn-coal text-gray-500 font-bold hover:text-primary transition-colors">Cancel</a>
          <button type="submit" class="btn btn-sm btn-primary px-6 font-bold shadow-sm">
            <%= @manager.persisted? ? "Apply Changes" : "Create Account" %>
          </button>
        </div>
      </div>
    <% end %>

    <script>
      document.addEventListener('change', function(e) {
        if (e.target && e.target.id === 'manager_avatar_input') {
          const file = e.target.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = function(event) {
              const previewContainer = document.getElementById('manager_avatar_preview_container');
              let previewImg = document.getElementById('manager_avatar_preview');
              
              if (!previewImg) {
                previewImg = document.createElement('img');
                previewImg.id = 'manager_avatar_preview';
                previewImg.className = 'size-full object-cover';
                previewContainer.innerHTML = '';
                previewContainer.appendChild(previewImg);
              }
              
              previewImg.src = event.target.result;
            };
            reader.readAsDataURL(file);
          }
        }
      });
    </script>
