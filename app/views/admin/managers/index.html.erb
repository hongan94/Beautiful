<!-- Beautiful SaaS Managers Dashboard -->
      <div class="container-fixed" id="content_container"></div>

      <div class="container-fixed">
        <div class="flex flex-wrap items-center lg:items-end justify-between gap-7 pb-10">
          <div class="flex flex-col justify-center gap-3">
            <h1 class="text-2xl font-bold leading-tight text-gray-900 dark:text-white">
              Managers
            </h1>
          </div>
          <div class="flex items-center gap-3">
            <%= button_to '#', method: :get, class: "btn btn-sm btn-light dark:bg-coal-400 dark:border-gray-700 dark:text-gray-300", id: "export-excel-btn", form: { id: "export-excel-form", style: "display:inline" }, data: { export_url: export_excel_admin_managers_path(format: :xlsx) } do %>
              <i class="ki-filled ki-file text-primary me-1 text-lg"></i>
              Export Excel
            <% end %>
            <%= link_to new_admin_manager_path, class: "btn btn-sm btn-primary py-2 px-4 rounded-lg shadow-sm font-medium flex items-center transition-colors hover:bg-primary-active" do %>
              <i class="ki-filled ki-plus me-2 text-lg"></i>
              Add Manager
            <% end %>
          </div>
        </div>
      </div>

      <%= render 'admin/shared/notify', notice: notice, alert: alert %>
      
      <div class="container-fixed">
        <div class="grid gap-7 lg:gap-10">
          <div class="card card-grid min-w-full bg-white dark:bg-coal-600 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm overflow-hidden">
            <%= render 'admin/managers/partial/search' %>
            <div class="card-body bg-transparent p-0">
              <div data-datatable="true" data-datatable-page-size="10" id="managers_table">
                <div class="scrollable-x-auto">
                  <%= render 'admin/managers/partial/table' %>
                </div>
                <div class="p-5 border-t border-gray-200 dark:border-gray-700">
                  <%= render 'admin/managers/partial/pagy' %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
