<div class="container-fixed max-w-[800px] mb-10">
  <div class="flex flex-col gap-3 mb-10">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @api_key.new_record? ? 'Generate New API Key' : 'Edit API Key' %></h1>
    <p class="text-sm text-gray-500 font-medium">Define access name and expiration for your service portal.</p>
  </div>

  <div class="card card-grid shadow-lg border border-gray-100 dark:border-gray-700 bg-white dark:bg-coal-600 rounded-xl overflow-hidden">
    <%= form_with model: [:admin, @api_key], local: true, class: "card-body py-8 px-10" do |f| %>
      <% if @api_key.errors.any? %>
        <div class="alert alert-danger mb-6 flex items-start gap-4 p-4 rounded-lg bg-red-50 text-red-700 border border-red-200">
          <i class="ki-filled ki-information text-xl mt-0.5"></i>
          <div>
            <h4 class="font-bold mb-1">Could not save API Key:</h4>
            <ul class="list-disc list-inside text-sm">
              <% @api_key.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <div class="flex flex-col gap-6">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold text-gray-700 dark:text-gray-200 uppercase tracking-wide">Key Name</label>
          <%= f.text_field :name, class: "input input-lg w-full bg-gray-50 dark:bg-coal-700 border border-gray-200 dark:border-gray-600 rounded-lg p-3 text-gray-800 dark:text-white focus:border-primary-active transition-all outline-none", placeholder: "e.g. Mobile App Frontend, External CRM Sync" %>
          <span class="text-3xs text-gray-400 font-medium italic">A descriptive name to help you identify this key later.</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold text-gray-700 dark:text-gray-200 uppercase tracking-wide">Status</label>
            <%= f.select :status, ApiKey.statuses.keys.map { |k| [k.capitalize, k] }, {}, class: "select select-lg w-full bg-gray-50 dark:bg-coal-700 border border-gray-200 dark:border-gray-600 rounded-lg p-3 text-gray-800 dark:text-white outline-none" %>
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold text-gray-700 dark:text-gray-200 uppercase tracking-wide">Expiration Date</label>
            <%= f.datetime_field :expires_at, class: "input input-lg w-full bg-gray-50 dark:bg-coal-700 border border-gray-200 dark:border-gray-600 rounded-lg p-3 text-gray-800 dark:text-white outline-none" %>
            <span class="text-3xs text-gray-400 font-medium">Leave blank for a permanent key.</span>
          </div>
        </div>

        <div class="card-footer py-6 border-t border-gray-100 dark:border-gray-700 mt-4 flex items-center justify-end gap-3">
          <a href="<%= admin_api_keys_path %>" class="btn btn-sm btn-light border border-gray-200 dark:border-gray-600">Cancel</a>
          <%= f.submit @api_key.new_record? ? "Create & Generate key" : "Update Key", class: "btn btn-sm btn-primary shadow-md hover:bg-primary-active transition" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
