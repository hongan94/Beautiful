<script>
  // Advanced Drag & Drop + Interaction Visuals
  document.addEventListener('turbo:load', function() {
    const grid = document.getElementById('media-grid');
    const form = document.getElementById('media-upload-form');
    const input = document.getElementById('bulk-upload');

    if (grid && form && input) {
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        grid.addEventListener(eventName, preventDefaults, false);
      });

      function preventDefaults (e) {
        e.preventDefault();
        e.stopPropagation();
      }

      ['dragenter', 'dragover'].forEach(eventName => {
        grid.addEventListener(eventName, () => {
          grid.classList.add('scale-[0.99]', 'bg-primary/[0.01]');
        }, false);
      });

      ['dragleave', 'drop'].forEach(eventName => {
        grid.addEventListener(eventName, () => {
          grid.classList.remove('scale-[0.99]', 'bg-primary/[0.01]');
        }, false);
      });

      grid.addEventListener('drop', handleDrop, false);

      function handleDrop(e) {
        const dt = e.dataTransfer;
        const files = dt.files;
        input.files = files;
        form.submit();
      }
    }
  });
</script>
