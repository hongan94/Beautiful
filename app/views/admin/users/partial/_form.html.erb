<div class="card bg-white dark:bg-coal-600 shadow-sm rounded-2xl border border-gray-200 dark:border-gray-700">
  <%= form_with(model: [:admin, @user], local: true, class: "") do |form| %>
    <div class="p-8 lg:p-10 space-y-12">
      <% if @user.errors.any? %>
        <div class="bg-danger/10 text-danger p-4 rounded-xl mb-4 border border-danger/20">
          <h2 class="font-bold mb-2 flex items-center uppercase text-xs tracking-wider"><i class="ki-filled ki-warning-2 text-lg me-2"></i> Fix these issues:</h2>
          <ul class="list-disc list-inside text-sm ms-2">
            <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <!-- Profile Information -->
      <div class="space-y-10">
        <div class="flex items-center gap-2 pb-2 border-b border-gray-100 dark:border-gray-700">
          <i class="ki-filled ki-profile-circle text-primary text-2xl"></i>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white uppercase tracking-tight">Personal Identity</h3>
        </div>

        <div class="flex items-center gap-8 px-2">
          <div class="relative group size-24 rounded-full border-2 border-primary/20 dark:border-primary/10 overflow-hidden cursor-pointer shadow-md ring-4 ring-primary/5">
            <div id="avatar_preview_container" class="size-full">
              <% if @user.avatar_url.attached? %>
                <%= image_tag @user.avatar_url, id: "avatar_preview", class: "size-full object-cover" %>
              <% else %>
                <div class="size-full bg-primary/5 dark:bg-primary/10 flex items-center justify-center">
                  <i id="avatar_placeholder_icon" class="ki-filled ki-user text-4xl text-primary/40"></i>
                </div>
              <% end %>
            </div>
            <%= form.file_field :avatar_url, id: "avatar_input", class: "absolute inset-0 opacity-0 cursor-pointer w-full h-full z-10", accept: "image/*" %>
            <div class="absolute inset-0 bg-primary/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center pointer-events-none">
              <i class="ki-filled ki-camera text-white text-2xl"></i>
            </div>
          </div>
          <div>
            <h4 class="text-base font-bold text-gray-800 dark:text-gray-100">Identity Visual</h4>
            <p class="text-xs font-medium text-gray-500">Professional portrait recommended</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
          <div class="space-y-2">
            <%= form.label :first_name, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.text_field :first_name, class: "input w-full h-12 px-5 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary/20 focus:border-primary transition-all font-medium", placeholder: "First Name", required: true %>
          </div>
          <div class="space-y-2">
            <%= form.label :last_name, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.text_field :last_name, class: "input w-full h-12 px-5 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary/20 focus:border-primary transition-all font-medium", placeholder: "Last Name", required: true %>
          </div>
          <div class="space-y-2">
            <%= form.label :email_address, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.email_field :email_address, class: "input w-full h-12 px-5 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary/20 focus:border-primary transition-all font-medium", placeholder: "Email", required: true %>
          </div>
          <div class="space-y-2">
            <%= form.label :phone_number, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.text_field :phone_number, class: "input w-full h-12 px-5 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary/20 focus:border-primary transition-all font-medium", placeholder: "Phone number" %>
          </div>
          <div class="space-y-2">
            <%= form.label :gender, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.select :gender, User.genders.keys.map { |g| [g.titleize, g] }, {}, class: "select w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 focus:border-primary" %>
          </div>
          <div class="space-y-2">
             <%= form.label :status, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
             <%= form.select :status, User.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "select w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 focus:border-primary" %>
          </div>
          <div class="md:col-span-2 space-y-2">
            <%= form.label :address, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.text_field :address, class: "input w-full h-12 px-5 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-primary/20 focus:border-primary transition-all font-medium", placeholder: "Full residence address" %>
          </div>
        </div>
      </div>

      <!-- System Permissions -->
      <div class="space-y-10 pt-4">
        <div class="flex items-center gap-2 pb-2 border-b border-emerald-100 dark:border-emerald-900/30">
          <i class="ki-filled ki-shield-tick text-emerald-500 text-2xl"></i>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white uppercase tracking-tight">Security & Governance</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
          <div class="space-y-2">
            <%= form.label :role, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, class: "select w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 focus:border-emerald-500" %>
          </div>
          <div class="space-y-2">
            <%= form.label :user_group_id, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.collection_select :user_group_id, UserGroup.all, :id, :name, { include_blank: "Member (No Group)" }, class: "select w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 focus:border-emerald-500" %>
          </div>
          <div class="space-y-2">
            <%= form.label :password, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.password_field :password, class: "input w-full h-12 px-5 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-emerald-500/10 focus:border-emerald-500 transition-all font-medium", placeholder: "Secure Password" %>
          </div>
          <div class="space-y-2">
            <%= form.label :password_confirmation, class: "text-sm font-bold text-gray-700 dark:text-gray-300" %>
            <%= form.password_field :password_confirmation, class: "input w-full h-12 px-5 rounded-xl border-gray-200 dark:border-gray-700 bg-white dark:bg-coal-700 focus:ring-emerald-500/10 focus:border-emerald-500 transition-all font-medium", placeholder: "Verification" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Actions -->
    <div class="px-8 py-6 flex items-center justify-end gap-3 border-t border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-coal-700/30 rounded-b-2xl">
      <a href="<%= admin_users_path %>" class="btn btn-sm btn-light dark:btn-coal text-gray-500 font-bold hover:text-primary transition-all hover:scale-105">Discard</a>
      <button type="submit" class="btn btn-primary px-8 py-3 rounded-xl font-black text-sm uppercase tracking-widest shadow-xl shadow-primary/20 hover:shadow-primary/40 hover:scale-[1.05] active:scale-95 transition-all bg-gradient-to-r from-primary to-blue-600 border-none">
         <%= @user.persisted? ? "Apply Identity" : "Deploy User" %>
      </button>
    </div>
  <% end %>

  <script>
    document.addEventListener('change', function(e) {
      if (e.target && e.target.id === 'avatar_input') {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(event) {
            const previewContainer = document.getElementById('avatar_preview_container');
            let previewImg = document.getElementById('avatar_preview');
            
            if (!previewImg) {
              previewImg = document.createElement('img');
              previewImg.id = 'avatar_preview';
              previewImg.className = 'size-full object-cover';
              previewContainer.innerHTML = '';
              previewContainer.appendChild(previewImg);
            }
            
            previewImg.src = event.target.result;
          };
          reader.readAsDataURL(file);
        }
      }
    });
  </script>
</div>
