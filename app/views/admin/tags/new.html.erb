<div class="container-fixed p-6">
  <div class="mb-6 flex items-center">
    <a href="<%= admin_tags_path %>" class="text-gray-500 hover:text-primary me-4">
      <i class="ki-filled ki-arrow-left text-xl"></i>
    </a>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @tag.new_record? ? "New Tag" : "Edit Tag" %></h1>
  </div>
  
  <div class="bg-white dark:bg-coal-500 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-6 max-w-xl">
    <%= form_with(model: [:admin, @tag], local: true, class: "space-y-6") do |form| %>
      <% if @tag.errors.any? %>
        <div class="bg-danger/10 text-danger p-4 rounded-lg mb-6">
          <ul class="list-disc list-inside text-sm">
            <% @tag.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= form.text_field :name, class: "input w-full px-4 py-2 border rounded-lg focus:ring-primary dark:bg-coal-600 dark:border-gray-600 dark:text-gray-200", placeholder: "e.g. Technology", required: true %>
      </div>

      <div>
        <%= form.label :slug, "URL Slug (Optional)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= form.text_field :slug, class: "input w-full px-4 py-2 border rounded-lg focus:ring-primary dark:bg-coal-600 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div class="flex justify-end gap-3 pt-6 border-t border-gray-200 dark:border-gray-700">
        <a href="<%= admin_tags_path %>" class="btn btn-light py-2 px-6 rounded-lg font-medium">Cancel</a>
        <%= form.submit "Save Tag", class: "btn btn-primary dark:bg-primary text-white py-2 px-6 rounded-lg font-medium cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
