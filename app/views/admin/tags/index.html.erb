<div class="container-fixed p-6">
  <div class="flex flex-col md:flex-row items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 md:mb-0">Tags</h1>
    <a href="<%= new_admin_tag_path %>" class="btn btn-primary dark:bg-primary py-2 px-4 rounded-lg shadow-sm font-medium flex items-center transition-colors">
      <i class="ki-filled ki-plus me-2"></i> Add Tag
    </a>
  </div>

  <div class="bg-white dark:bg-coal-500 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-left align-middle text-gray-600 dark:text-gray-300">
      <thead class="bg-gray-50 dark:bg-coal-600/50 border-b border-gray-200 dark:border-gray-700 text-xs uppercase font-medium text-gray-500">
        <tr>
          <th class="py-3 px-6">Name</th>
          <th class="py-3 px-6">Slug</th>
          <th class="py-3 px-6 text-center">Articles Count</th>
          <th class="py-3 px-6 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @tags.each do |tag| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-coal-400/30 transition-colors">
            <td class="py-4 px-6 font-medium text-gray-900 dark:text-gray-100"><%= tag.name %></td>
            <td class="py-4 px-6 text-gray-500 dark:text-gray-400">/<%= tag.slug %></td>
            <td class="py-4 px-6 text-center">
              <span class="inline-flex px-2 py-1 bg-gray-100 dark:bg-coal-600 rounded text-xs"><%= tag.articles.count %></span>
            </td>
            <td class="py-4 px-6 text-right space-x-2">
              <a href="<%= edit_admin_tag_path(tag) %>" class="inline-flex text-gray-500 hover:text-primary transition-colors cursor-pointer">
                <i class="ki-filled ki-pencil text-lg"></i>
              </a>
              <%= button_to admin_tag_path(tag), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "inline-flex text-gray-500 hover:text-danger transition-colors cursor-pointer" do %>
                <i class="ki-filled ki-trash text-lg"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
