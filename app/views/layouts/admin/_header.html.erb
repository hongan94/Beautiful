    <header class="header fixed top-0 z-10 start-0 end-0 flex items-stretch shrink-0 bg-[--tw-page-bg] dark:bg-[--tw-page-bg-dark]" data-sticky="true" data-sticky-class="shadow-sm" data-sticky-name="header" id="header">
        <div class="container-fixed flex justify-end items-stretch lg:gap-4" id="header_container">
    
        <div class="menu ml-auto" data-menu="true">
        <div class="menu-item menu-item-dropdown" data-menu-item-offset="20px, 10px" data-menu-item-placement="bottom-end" data-menu-item-toggle="dropdown" data-menu-item-trigger="click|lg:click">
         <div class="menu-toggle btn btn-icon rounded-full">
          <% if Current.user&.avatar_url&.attached? %>
            <%= image_tag Current.user.avatar_url, alt: Current.user.name, class: "size-9 rounded-full border-2 border-success shrink-0 object-cover" %>
          <% else %>
            <div class="size-9 rounded-full border-2 border-success shrink-0 bg-primary/10 text-primary flex items-center justify-center font-bold">
              <%= Current.user&.first_name&.first || 'A' %>
            </div>
          <% end %>
         </div>

         <div class="menu-dropdown menu-default light:border-gray-300 w-screen max-w-[250px] overflow-hidden rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 bg-white dark:bg-coal-500">
          
          <!-- User Profile Info -->
          <div class="flex items-center px-4 py-3 gap-3 bg-gray-50/50 dark:bg-coal-600/30">
            <% if Current.user&.avatar_url&.attached? %>
              <%= image_tag Current.user.avatar_url, alt: Current.user.name, class: "size-10 rounded-full border-2 border-success object-cover" %>
            <% else %>
              <div class="size-10 rounded-full border-2 border-success bg-primary/10 text-primary flex items-center justify-center font-bold text-lg">
                <%= Current.user&.first_name&.first || 'A' %>
              </div>
            <% end %>
            <div class="flex flex-col gap-1 overflow-hidden">
               <span class="text-sm text-gray-800 dark:text-gray-100 font-semibold leading-none truncate block">
                <%= Current.user ? Current.user.name : "System Admin" %>
               </span>
               <span class="text-xs text-gray-500 dark:text-gray-400 font-medium leading-none truncate block">
                <%= Current.user ? Current.user.email_address : "admin@system.local" %>
               </span>
            </div>
          </div>
          
          <div class="menu-separator border-b border-gray-100 dark:border-gray-700"></div>

          <div class="flex flex-col py-2 p-2">
           <!-- Links -->
           <div class="menu-item mb-1">
            <a class="menu-link px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-coal-400 transition-colors flex items-center gap-2" href="<%= Current.user ? edit_admin_user_path(Current.user) : '#' %>">
             <span class="menu-icon text-gray-400">
              <i class="ki-filled ki-profile-circle text-lg"></i>
             </span>
             <span class="menu-title text-sm font-medium text-gray-700 dark:text-gray-200">
              My Profile
             </span>
             <span class="badge badge-xs text-3xs font-bold badge-primary badge-outline py-0.5 px-1.5 ms-auto">
              <%= Current.user&.role&.capitalize || 'Admin' %>
             </span>
            </a>
           </div>

           <div class="menu-item mb-1">
            <a class="menu-link px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-coal-400 transition-colors flex items-center gap-2" href="<%= admin_settings_path %>">
             <span class="menu-icon text-gray-400">
              <i class="ki-filled ki-setting-2 text-lg"></i>
             </span>
             <span class="menu-title text-sm font-medium text-gray-700 dark:text-gray-200">
              System Settings
             </span>
            </a>
           </div>

           <div class="menu-item mb-1">
            <a class="menu-link px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-coal-400 transition-colors flex items-center gap-2" href="<%= admin_activity_logs_path %>">
             <span class="menu-icon text-gray-400">
              <i class="ki-filled ki-time text-lg"></i>
             </span>
             <span class="menu-title text-sm font-medium text-gray-700 dark:text-gray-200">
              Activity Logs
             </span>
            </a>
           </div>

           <div class="menu-separator my-1 border-b border-gray-100 dark:border-gray-700"></div>

           <!-- Features Toggle -->
           <div class="menu-item mb-1">
            <div class="menu-link px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-coal-400 transition-colors flex items-center gap-2 justify-between">
             <div class="flex items-center gap-2">
               <span class="menu-icon text-gray-400">
                <i class="ki-filled ki-moon text-lg"></i>
               </span>
               <span class="menu-title text-sm font-medium text-gray-700 dark:text-gray-200">
                Dark Mode
               </span>
             </div>
             <label class="switch switch-sm cursor-pointer">
              <input data-theme-state="dark" data-theme-toggle="true" name="check" type="checkbox" value="1">
             </label>
            </div>
           </div>
           
           <!-- Language Selector -->
           <div class="menu-item menu-item-dropdown" data-menu-item-offset="-5px, 0" data-menu-item-placement="left-start" data-menu-item-toggle="dropdown" data-menu-item-trigger="click|lg:hover">
            <div class="menu-link px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-coal-400 transition-colors flex items-center justify-between cursor-pointer">
             <div class="flex items-center gap-2">
               <span class="menu-icon text-gray-400">
                <i class="ki-filled ki-global text-lg"></i>
               </span>
               <span class="menu-title text-sm font-medium text-gray-700 dark:text-gray-200">
                Language
               </span>
             </div>
             <div class="flex items-center gap-1.5 text-xs text-gray-500 font-medium">
              EN
              <%= image_tag "flags/united-states.svg", alt: "EN", class: "size-3.5 rounded-sm object-cover" %>
             </div>
            </div>
            
            <div class="menu-dropdown menu-default light:border-gray-300 w-full max-w-[150px] p-2 bg-white dark:bg-coal-500 border border-gray-100 dark:border-gray-700 rounded-lg shadow-md">
             <div class="menu-item active mb-1">
              <a class="menu-link px-3 py-2 rounded-md hover:bg-gray-100 dark:hover:bg-coal-400 flex items-center gap-2" href="?lang=en">
               <span class="menu-icon">
                <%= image_tag "flags/united-states.svg", alt: "EN", class: "size-4 rounded-sm" %>
               </span>
               <span class="menu-title text-sm font-medium text-gray-700 dark:text-gray-200">English</span>
               <i class="ki-solid ki-check text-success ms-auto text-sm"></i>
              </a>
             </div>
             <div class="menu-item">
              <a class="menu-link px-3 py-2 rounded-md hover:bg-gray-100 dark:hover:bg-coal-400 flex items-center gap-2" href="?lang=vi">
               <span class="menu-icon">
                <%= image_tag "flags/vietnam.svg", alt: "VI", class: "size-4 rounded-sm" %>
               </span>
               <span class="menu-title text-sm font-medium text-gray-700 dark:text-gray-200">Tiếng Việt</span>
              </a>
             </div>
            </div>
           </div>

           <div class="mt-2 pt-2 border-t border-gray-100 dark:border-gray-700">
            <%= button_to sign_out_session_path, method: :delete, class: "btn btn-light dark:bg-coal-400 hover:text-danger w-full justify-center transition-colors cursor-pointer rounded-lg text-sm font-medium py-2 shadow-sm border border-gray-200 dark:border-gray-600" do %>
              <i class="ki-filled ki-exit-right text-lg me-2"></i> Log out
            <% end %>
           </div>
          </div>
         </div>
        </div>
       </div>
        </div>
    </header>