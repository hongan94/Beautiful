<div class="flex items-center justify-center grow bg-center bg-no-repeat page-bg">
   <div class="card max-w-[440px] w-full">
    <div action="#" class="card-body p-10" id="check_email_form" method="post">
     <div class="flex justify-center py-10">
      <%= image_tag "illustrations/30.svg", alt: "image", class: "dark:hidden max-h-[130px]" %>
      <%= image_tag "illustrations/30-dark.svg", alt: "image", class: "light:hidden max-h-[130px]" %>
     </div>
     <h3 class="text-lg font-medium text-gray-900 text-center mb-3">
      Check your email
     </h3>
     <div class="text-2sm text-center text-gray-700 mb-7.5">
      Please click the link sent to your email
      <a class="text-2sm text-gray-900 font-medium hover:text-primary-active" href="#">
       bob@reui.io
      </a>
      <br/>
      to verify your account. Thank you
     </div>
     <div class="flex justify-center mb-5">
      <%= link_to "Back to Home", sign_in_session_path, class: "btn btn-primary flex justify-center" %>
     </div>
     <div class="flex items-center justify-center gap-1">
      <span class="text-xs text-gray-700">
       Didn’t receive an email?
      </span>
      <a class="text-xs font-medium link" href="html/demo1/authentication/classic/sign-in.html">
       Resend
      </a>
     </div>
    </div>
   </div>
  </div>